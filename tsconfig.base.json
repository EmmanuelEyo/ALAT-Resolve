{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["DOM", "ES2022"],
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "types": ["node"],
    "paths": {
      "@ui/*": ["packages/ui/*"],
      "@types/*": ["packages/types/*"],
      "@db/*": ["packages/db/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
